<UserControl x:Class="Pulse.UI.Pages.GoalsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:domain="clr-namespace:Pulse.Domain.Enums;assembly=Pulse.Domain">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <TextBlock Text="Goals" Style="{StaticResource PageTitle}" VerticalAlignment="Center" />
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="12"
                        Background="#7C4DFF" BorderBrush="#7C4DFF"
                        Command="{Binding OpenCreateDialogCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="New Goal" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Create Dialog (inline) -->
            <Border Visibility="{Binding IsCreateDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Style="{StaticResource CardStyle}" Margin="8,0,8,20">
                <StackPanel>
                    <TextBlock Text="Create New Goal" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,16" />

                    <TextBox materialDesign:HintAssist.Hint="Goal title (e.g., Code for 4 hours)"
                             Text="{Binding NewGoalTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,12" FontSize="14" />

                    <TextBox materialDesign:HintAssist.Hint="Description (optional)"
                             Text="{Binding NewGoalDescription, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,12" FontSize="14" />

                    <TextBox materialDesign:HintAssist.Hint="Tracked processes (comma-separated, e.g., devenv,code,rider64)"
                             Text="{Binding NewGoalProcesses, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,12" FontSize="14" />

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Type" FontSize="12" Foreground="#888" Margin="0,0,0,6" />
                            <ComboBox SelectedItem="{Binding NewGoalType}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      FontSize="14">
                                <domain:GoalType>Target</domain:GoalType>
                                <domain:GoalType>Limit</domain:GoalType>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0">
                            <TextBlock Text="Hours" FontSize="12" Foreground="#888" Margin="0,0,0,6" />
                            <TextBox Text="{Binding NewGoalHours, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="8,0,0,0">
                            <TextBlock Text="Minutes" FontSize="12" Foreground="#888" Margin="0,0,0,6" />
                            <TextBox Text="{Binding NewGoalMinutes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#888" Margin="0,0,8,0"
                                Command="{Binding OpenCreateDialogCommand}" />
                        <Button Content="Create Goal"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#7C4DFF" BorderBrush="#7C4DFF"
                                materialDesign:ButtonAssist.CornerRadius="10"
                                Command="{Binding CreateGoalCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Goals List -->
            <ItemsControl ItemsSource="{Binding Goals}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Goal Info -->
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <materialDesign:PackIcon Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Setter Property="Kind" Value="Target" />
                                                    <Setter Property="Foreground" Value="#7C4DFF" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="Limit">
                                                            <Setter Property="Kind" Value="ShieldAlert" />
                                                            <Setter Property="Foreground" Value="#FF9800" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>
                                        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                                        <Border CornerRadius="6" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1A237E" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="Limit">
                                                            <Setter Property="Background" Value="#4A2800" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10" FontWeight="Medium">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="TARGET" />
                                                        <Setter Property="Foreground" Value="#7C4DFF" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="Limit">
                                                                <Setter Property="Text" Value="LIMIT" />
                                                                <Setter Property="Foreground" Value="#FF9800" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>

                                    <!-- Progress Bar -->
                                    <ProgressBar Value="{Binding ProgressPercent}" Height="10" Margin="0,8,40,0"
                                                 materialDesign:TransitionAssist.DisableTransitions="True"
                                                 Foreground="#7C4DFF" Background="#252540" />

                                    <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="#888">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:hh\:mm} / {1:hh\:mm}  •  {2:0}% complete">
                                                <Binding Path="CurrentDuration" />
                                                <Binding Path="TargetDuration" />
                                                <Binding Path="ProgressPercent" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Streak & Actions -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" MinWidth="80">
                                    <TextBlock Text="{Binding CurrentStreak}" FontSize="28" FontWeight="Bold"
                                               Foreground="#FF9800" HorizontalAlignment="Center" />
                                    <TextBlock Text="day streak" FontSize="11" Foreground="#888" HorizontalAlignment="Center" />
                                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                                            Content="Delete" FontSize="11" Foreground="#F44336" Margin="0,8,0,0" Padding="6,2"
                                            Command="{Binding DataContext.DeleteGoalCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding GoalId}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="No goals yet. Click 'New Goal' to create your first productivity goal!"
                       FontSize="14" Foreground="#555" HorizontalAlignment="Center" Margin="0,40,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Goals.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

        </StackPanel>
    </ScrollViewer>
</UserControl>
