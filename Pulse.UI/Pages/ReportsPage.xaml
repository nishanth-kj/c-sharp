<UserControl x:Class="Pulse.UI.Pages.ReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <!-- Header with Date Range Picker -->
            <Grid Margin="0,0,0,24">
                <TextBlock Text="Reports" Style="{StaticResource PageTitle}" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <DatePicker SelectedDate="{Binding StartDate}" Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                materialDesign:HintAssist.Hint="From" Width="140" Margin="0,0,10,0" />
                    <DatePicker SelectedDate="{Binding EndDate}" Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                materialDesign:HintAssist.Hint="To" Width="140" Margin="0,0,10,0" />
                    <Button Style="{StaticResource MaterialDesignIconButton}" Command="{Binding RefreshCommand}"
                            Foreground="#7C4DFF" ToolTip="Refresh">
                        <materialDesign:PackIcon Kind="Refresh" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Summary Cards -->
            <UniformGrid Columns="3" Margin="0,0,0,16">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="ClockOutline" Width="22" Height="22" Foreground="#7C4DFF" />
                            <TextBlock Text="Total Time" FontSize="12" Foreground="#888" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding TotalTime}" FontSize="28" FontWeight="Bold" Foreground="White" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="CalendarClock" Width="22" Height="22" Foreground="#00BFA5" />
                            <TextBlock Text="Avg / Day" FontSize="12" Foreground="#888" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding AvgPerDay}" FontSize="28" FontWeight="Bold" Foreground="#00BFA5" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="ChartArc" Width="22" Height="22" Foreground="#FF9800" />
                            <TextBlock Text="Avg Score" FontSize="12" Foreground="#888" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding AvgScore}" FontSize="28" FontWeight="Bold" Foreground="#FF9800" />
                            <TextBlock Text="%" FontSize="16" Foreground="#FF9800" VerticalAlignment="Bottom" Margin="2,0,0,5" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Charts Row -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Trend Line Chart -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Usage Trend" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,12" />
                        <lvc:CartesianChart Series="{Binding TrendSeries}" Height="260"
                                            XAxes="{Binding TrendXAxes}"
                                            YAxes="{Binding TrendYAxes}"
                                            ZoomMode="None" />
                    </StackPanel>
                </Border>

                <!-- Category Pie Chart -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="By Category" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,12" />
                        <lvc:PieChart Series="{Binding CategorySeries}" Height="260"
                                      InitialRotation="-90" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Top Apps Table -->
            <Border Style="{StaticResource CardStyle}" Margin="8,0,8,16">
                <StackPanel>
                    <TextBlock Text="Top Applications" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#" FontSize="12" FontWeight="SemiBold" Foreground="#888" />
                        <TextBlock Grid.Column="1" Text="Application" FontSize="12" FontWeight="SemiBold" Foreground="#888" />
                        <TextBlock Grid.Column="2" Text="Total Time" FontSize="12" FontWeight="SemiBold" Foreground="#888" />
                        <TextBlock Grid.Column="3" Text="Sessions" FontSize="12" FontWeight="SemiBold" Foreground="#888" />
                        <TextBlock Grid.Column="4" Text="Category" FontSize="12" FontWeight="SemiBold" Foreground="#888" />
                    </Grid>
                    <Separator Background="#252540" Margin="0,0,0,4" />

                    <ItemsControl ItemsSource="{Binding TopApps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#16162E" CornerRadius="8" Padding="12,10" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontSize="14" FontWeight="Bold" Foreground="#7C4DFF" VerticalAlignment="Center"
                                                   Text="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex), StringFormat='#{0}'}" />
                                        <TextBlock Grid.Column="1" Text="{Binding ProcessName}" FontSize="14" Foreground="White" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding TotalDuration, StringFormat='{}{0:hh\\:mm\\:ss}'}" FontSize="14" FontWeight="Medium" Foreground="#00BFA5" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding SessionCount}" FontSize="14" Foreground="#888" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="4" FontSize="12" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding CategoryName}" />
                                                    <Setter Property="Foreground" Value="#888" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CategoryName}" Value="{x:Null}">
                                                            <Setter Property="Text" Value="—" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
