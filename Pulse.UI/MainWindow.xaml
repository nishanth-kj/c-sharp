<Window x:Class="Pulse.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:Pulse.UI.ViewModels"
        xmlns:pages="clr-namespace:Pulse.UI.Pages"
        Title="Pulse — Desktop Activity Manager"
        Height="820" Width="1280" MinHeight="700" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D1A"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <pages:DashboardPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ApplicationsViewModel}">
            <pages:ApplicationsPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GoalsViewModel}">
            <pages:GoalsPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <pages:ReportsPage />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- === Sidebar === -->
        <Border Grid.Column="0" Background="#12122A" CornerRadius="0,24,24,0">
            <DockPanel Margin="0,16,0,16">

                <!-- App Logo & Name -->
                <StackPanel DockPanel.Dock="Top" Margin="24,16,24,32">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <materialDesign:PackIcon Kind="Pulse" Width="36" Height="36"
                                                  Foreground="#7C4DFF" Margin="0,0,12,0" VerticalAlignment="Center" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Pulse" FontSize="22" FontWeight="Bold" Foreground="White" />
                            <TextBlock Text="Activity Manager" FontSize="10" Foreground="#888" Margin="0,-2,0,0" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Tracking Status Indicator -->
                <Border DockPanel.Dock="Top" Background="#1A1A3A" CornerRadius="12" Margin="16,0,16,24" Padding="16,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#4CAF50" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTracking}" Value="False">
                                                <Setter Property="Fill" Value="#F44336" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding TrackingStatus}" FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding ActiveAppName}" FontSize="11" Foreground="#888" Margin="18,4,0,0" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding SessionDuration}" FontSize="20" FontWeight="Bold" Foreground="#7C4DFF" Margin="18,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Navigation Items -->
                <StackPanel DockPanel.Dock="Top" Margin="12,0">
                    <RadioButton x:Name="NavDashboard" Style="{StaticResource MaterialDesignTabRadioButtonBottom}"
                                 IsChecked="True" Margin="0,2" Padding="16,14"
                                 Command="{Binding NavigateToCommand}" CommandParameter="Dashboard"
                                 HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="Dashboard" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButtonBottom}"
                                 Margin="0,2" Padding="16,14"
                                 Command="{Binding NavigateToCommand}" CommandParameter="Applications"
                                 HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Apps" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="Applications" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButtonBottom}"
                                 Margin="0,2" Padding="16,14"
                                 Command="{Binding NavigateToCommand}" CommandParameter="Goals"
                                 HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Target" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="Goals" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButtonBottom}"
                                 Margin="0,2" Padding="16,14"
                                 Command="{Binding NavigateToCommand}" CommandParameter="Reports"
                                 HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ChartLine" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="Reports" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- Bottom Controls -->
                <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom" Margin="16,0,16,8">
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                            Content="{Binding TrackingStatus}" Margin="0,0,0,8"
                            Command="{Binding ToggleTrackingCommand}"
                            HorizontalAlignment="Stretch" Height="40"
                            materialDesign:ButtonAssist.CornerRadius="10" />
                    <StackPanel HorizontalAlignment="Center" Margin="0,8,0,0">
                        <TextBlock Text="{Binding CurrentTime}" FontSize="16" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding CurrentDate}" FontSize="11" Foreground="#666"
                                   HorizontalAlignment="Center" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- === Main Content Area === -->
        <Border Grid.Column="1" Margin="0">
            <ContentControl Content="{Binding CurrentViewModel}" Margin="32,24" />
        </Border>
    </Grid>
</Window>
