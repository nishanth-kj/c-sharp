# ================================================
# SharpIB Site — Environment Configuration
# ================================================
# Copy this file to .env and fill in the values.
# .env is excluded from git tracking.
#
# NOTE: For Blazor WebAssembly, configuration is read 
# from wwwroot/appsettings.json (the .NET equivalent).
# This .env file is provided for reference and can be
# used with tools that support it.
# ================================================

# GitHub API base URL (default: https://api.github.com)
API_BASE_URL=https://api.github.com

# GitHub repository (owner/repo format)
GITHUB_REPO=nishanth-kj/c-sharp
